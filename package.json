{
  "name": "operator-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A self-hostable workspace for reviewing, summarizing, and continuing agent coding sessions. Import threads from Claude Code / Codex / paste, promote insights, and keep chatting grounded in your own prior context.",
  "author": "David Lin-Clark <me@davidlinclark.com>",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "nextjs",
    "react",
    "drizzle",
    "postgres",
    "tailwind",
    "shadcn",
    "agent-sessions",
    "claude-code",
    "codex",
    "review-tool",
    "template"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 4200",
    "build": "next build",
    "start": "next start --port 4200",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/seed.ts",
    "db:seed:demo": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/seed.ts --demo",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "1.1.0",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "0.474.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "pg": "^8.16.3",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
