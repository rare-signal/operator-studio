# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
.next-prod/
.next-showcase/
out/
build/
dist/

# Generated showcase snapshot — regenerated by `pnpm showcase:snapshot`
# from `~/.claude/projects/`. Don't commit; the build script runs the
# snapshot before `next build`.
public/showcase-data/

# Showcase build script's intermediate backups (only present mid-build
# if a previous run died; restored automatically on next run).
**/*.showcase-disabled
**/*.showcase-orig-backup

# Per-host redaction overrides (your $USER, internal codenames, etc).
# The default `showcase-redactions.ts` ships clean / templated; this
# file merges in at snapshot time. Never commit machine-specific
# scrubbing rules.
scripts/showcase-redactions.local.ts

# Env files
.env
.env.local
.env.*.local

# Claude/Codex local worktrees are machine-local execution sandboxes.
.claude/worktrees/

# OS / editor
.DS_Store
*.log
.vscode/
.idea/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Drizzle / DB
*.db
*.db-journal

# Uploaded files (plan covers etc) — runtime artifact, never commit.
# Anchored to repo root so it doesn't shadow app/api/operator-studio/uploads/
# (which is the route handler that serves these files).
/uploads/

# ─── BETA / LOCAL-ONLY ─────────────────────────────────────────────────────
# The remote-control "dog-walk" surface. Spawns tmux sessions, captures the
# macOS screen, executes anything the operator asks. Absolutely not intended
# for the public OSS repo — this entire tree is gitignored by design.
# If you're reading this in a clone of the OSS repo, these files do not exist.
app/(operator-studio)/operator-studio/beta/
app/api/beta/
app/beta-remote/
BETA_README.md
.vercel

# Experimental mockup surfaces — kept local for ideation, not committed.
# `app/2/` is the older v2 sketch; `app/v3/` is the active vision-mockup
# with its own /v3 route. Promote into the main shell when an idea is
# ready to ship; until then these stay out of git.
app/2/
app/v3/

# Lane G "Cinema" — code-first product video R&D. Self-contained sub-project
# with its own package.json. Heavy dependencies (Remotion bundles Chromium),
# rendered artifacts, and capture caches all live here. Will graduate to its
# own repo if a bet earns it.
/experiments/
