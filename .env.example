# Postgres connection string. Required.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/operator_studio

# ─── Auth ────────────────────────────────────────────────────────────────────
# Leave OPERATOR_STUDIO_PASSWORD unset to run with no password gate. That's
# the default for local dev. Set it to any non-empty string to turn on a
# shared-password prompt. This is a dev convenience — not a security boundary.
# For public deployments, swap the session route for Auth.js / Clerk / WorkOS.
# OPERATOR_STUDIO_PASSWORD=

# ─── Admin allowlist ─────────────────────────────────────────────────────────
# Comma-separated list of display names allowed to hit /operator-studio/admin
# and the POST /api/operator-studio/tokens, /webhooks management endpoints.
# Unset = every authenticated caller is an admin (self-hosted-small-team
# default). Swap `isAdmin` in lib/operator-studio/auth.ts for anything more
# sophisticated (role claims, group lookups, etc).
# OPERATOR_STUDIO_ADMINS=alex,sam

# ─── Ingest API token (legacy shared secret) ────────────────────────────────
# For per-user tokens, use the Admin UI at /operator-studio/admin — it mints
# DB-backed tokens with per-token display-name attribution.
#
# This env var is a legacy single-shared-secret fallback. Set it if you need
# a quick token for a bootstrap script or don't want to run the admin UI yet.
# Callers pass it as Authorization: Bearer <token>. Generate one with
#   openssl rand -hex 32
# Leave unset in fully-open local dev — machine routes accept unauthenticated
# POSTs if BOTH this and OPERATOR_STUDIO_PASSWORD are empty.
# OPERATOR_STUDIO_INGEST_TOKEN=

# ─── Global webhook subscriber (zero-DB escape hatch) ───────────────────────
# Fires on every thread.imported and thread.promoted event across ALL
# workspaces. Useful for "announce to Slack" without configuring a row in
# the Admin UI. Per-workspace webhooks still fire alongside this.
# OPERATOR_STUDIO_PROMOTION_WEBHOOK_URL=
# OPERATOR_STUDIO_PROMOTION_WEBHOOK_SECRET=

# ─── Grounded-continuation chat ──────────────────────────────────────────────
# Comma-separated list of OpenAI-compatible chat/completions endpoints
# (local llama.cpp, vllm, ollama, LM Studio, or a cloud provider URL).
# Leave blank to have the chat endpoint echo your message (useful for
# first-run / UI-only exploration without a model backend).
WORKBOOK_CLUSTER_ENDPOINTS=

# Optional — model identifier sent to the endpoint.
WORKBOOK_CLUSTER_MODEL=gpt-3.5-turbo

# Optional — per-lane fallbacks for the grounded chat router.
WORKBOOK_FAST_ENDPOINTS=
WORKBOOK_BALANCED_ENDPOINTS=
WORKBOOK_DEEP_ENDPOINTS=

# Optional — timeout in ms for LLM requests.
WORKBOOK_CLUSTER_TIMEOUT_MS=60000

# Optional — grounding context budget for continuation chat, in tokens.
OPERATOR_STUDIO_CONTINUATION_CONTEXT_TOKENS=200000

# ─── Local discovery roots (agent session files on disk) ────────────────────
# Override paths for the Import → Discover UI. Defaults are ~/.claude/projects
# and ~/.codex/sessions. Override when your Claude Code / Codex installations
# keep session logs somewhere else.
#
# Separator is `:` on macOS/Linux, `;` on Windows (matches Node's path.delimiter).
#   Unix:     OPERATOR_STUDIO_CLAUDE_ROOTS=/home/alex/.claude/projects:/srv/shared/claude
#   Windows:  OPERATOR_STUDIO_CLAUDE_ROOTS=C:\Users\alex\.claude\projects;D:\shared\claude
# OPERATOR_STUDIO_CLAUDE_ROOTS=
# OPERATOR_STUDIO_CODEX_ROOTS=

# Optional — used for metadata / absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:4200
