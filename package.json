{
  "name": "operator-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A self-hostable workspace for reviewing, summarizing, and continuing agent coding sessions. Import threads from Claude Code / Codex / paste, promote insights, and keep chatting grounded in your own prior context.",
  "author": "David Lin-Clark <me@davidlinclark.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/rare-signal/operator-studio.git"
  },
  "bugs": "https://github.com/rare-signal/operator-studio/issues",
  "homepage": "https://github.com/rare-signal/operator-studio#readme",
  "keywords": [
    "nextjs",
    "react",
    "drizzle",
    "postgres",
    "tailwind",
    "shadcn",
    "agent-sessions",
    "claude-code",
    "codex",
    "review-tool",
    "template"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 4200",
    "build": "next build",
    "start": "next start --port 4200",
    "build:prod": "NEXT_DIST_DIR=.next-prod next build",
    "start:prod": "NEXT_DIST_DIR=.next-prod next start --port 4201",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/seed.ts",
    "db:seed:demo": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/seed.ts --demo",
    "db:studio": "drizzle-kit studio",
    "integrity:check": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/integrity-check.ts",
    "integrity:repair": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/integrity-check.ts --repair",
    "integrity:importers": "tsx ./scripts/check-importers.ts",
    "probe:importers": "tsx ./scripts/probe-importers.ts",
    "mcp:server": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/mcp-server.ts",
    "mcp:probe": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/mcp-probe.ts",
    "wayseer:search": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/wayseer-search.ts",
    "wayseer:plan": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/wayseer-plan.ts",
    "plan:card": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/plan-card.ts",
    "os:state": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-state.ts",
    "os:context": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-context.ts",
    "os:cache": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-context-cache.ts",
    "os:cycle": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-cycle.ts",
    "os:operations": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-operations.ts",
    "os:planners": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/planner-backends.ts",
    "os:workers": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/cockpit-workers.ts",
    "os:worker-done": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/cockpit-mark-done.ts",
    "os:ado": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/ado-lookup.ts",
    "os:ado-triage": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/ado-triage.ts",
    "os:hydrate": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/operator-hydrate.ts",
    "beta:devices": "node --import tsx --import ./scripts/tsx-loader-register.mjs --env-file-if-exists=.env.local --env-file-if-exists=.env ./scripts/beta-devices.ts",
    "showcase:snapshot": "tsx ./scripts/showcase-snapshot.ts",
    "showcase:build": "tsx ./scripts/showcase-build.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/postcss": "^4",
    "@types/three": "^0.184.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.44.5",
    "lucide-react": "0.474.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "pg": "^8.16.3",
    "postcss": "^8.5.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.1",
    "three": "^0.184.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "playwright-core": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
