# Postgres connection string. Required.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/operator_studio

# ─── Auth ────────────────────────────────────────────────────────────────────
# Leave OPERATOR_STUDIO_PASSWORD unset to run with no password gate. That's
# the default for local dev. Set it to any non-empty string to turn on a
# shared-password prompt. This is a dev convenience — not a security boundary.
# For public deployments, swap the session route for Auth.js / Clerk / WorkOS.
# OPERATOR_STUDIO_PASSWORD=

# ─── Ingest API token ───────────────────────────────────────────────────────
# Shared secret for programmatic ingestion via POST /api/operator-studio/ingest.
# Generate one with:  openssl rand -hex 32
# Callers pass it as Authorization: Bearer <token>. IDE hooks, shell scripts,
# and webhooks use this so they don't need a cookie session.
# Leave unset in fully-open local dev — the endpoint will accept unauthenticated
# POSTs if BOTH this and OPERATOR_STUDIO_PASSWORD are empty.
# OPERATOR_STUDIO_INGEST_TOKEN=

# ─── Grounded-continuation chat ──────────────────────────────────────────────
# Comma-separated list of OpenAI-compatible chat/completions endpoints
# (local llama.cpp, vllm, ollama, LM Studio, or a cloud provider URL).
# Leave blank to have the chat endpoint echo your message (useful for
# first-run / UI-only exploration without a model backend).
WORKBOOK_CLUSTER_ENDPOINTS=

# Optional — model identifier sent to the endpoint.
WORKBOOK_CLUSTER_MODEL=gpt-3.5-turbo

# Optional — per-lane fallbacks for the grounded chat router.
WORKBOOK_FAST_ENDPOINTS=
WORKBOOK_BALANCED_ENDPOINTS=
WORKBOOK_DEEP_ENDPOINTS=

# Optional — timeout in ms for LLM requests.
WORKBOOK_CLUSTER_TIMEOUT_MS=60000

# Optional — grounding context budget for continuation chat, in tokens.
OPERATOR_STUDIO_CONTINUATION_CONTEXT_TOKENS=200000

# Optional — used for metadata / absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:4200
